{
  "version": 2,
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/contact.js": { "maxDuration": 30 },
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/logos/(.*)", "dest": "/logos/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
